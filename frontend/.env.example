# ========================================
# Variables de Entorno - FreshFace E-commerce
# ========================================

# Backend API URL (REQUERIDO)
REACT_APP_BACKEND_URL=http://localhost:8070

# PayPal Configuration (REQUERIDO para pagos)
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_client_id_here
REACT_APP_PAYPAL_ENVIRONMENT=sandbox

# Cloudinary (REQUERIDO para subir imágenes)
REACT_APP_CLOUD_NAME_CLOUDINARY=your_cloudinary_cloud_name

# Google OAuth (OPCIONAL - solo si usas login con Google)
# REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id

# ========================================
# CONFIGURACIÓN PARA PRODUCCIÓN
# ========================================
# Cuando subas a producción, cambia:
# REACT_APP_BACKEND_URL=https://tu-backend-dominio.com
# REACT_APP_PAYPAL_ENVIRONMENT=production
# REACT_APP_PAYPAL_CLIENT_ID=tu_paypal_client_id_production
