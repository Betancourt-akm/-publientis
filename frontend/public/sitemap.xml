<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sitemap de Publientis - Plataforma de Vinculación Profesional Universitaria
  
  Estructura escalable: cuando se registren nuevas universidades o facultades,
  agregar sus rutas públicas aquí (ej: /universidades/udea, /universidades/unal).
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <!-- Página principal -->
  <url>
    <loc>https://publientis.online/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Landing informativa -->
  <url>
    <loc>https://publientis.online/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- Autenticación -->
  <url>
    <loc>https://publientis.online/login</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>https://publientis.online/sign-up</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>

  <!-- Ofertas y Productos (públicos) -->
  <url>
    <loc>https://publientis.online/ofertas</loc>
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://publientis.online/productos</loc>
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://publientis.online/categorias</loc>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>

  <!-- Contacto -->
  <url>
    <loc>https://publientis.online/contacto</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>

  <!--
    TODO: Rutas dinámicas por universidad/facultad (escalabilidad SaaS)
    Ejemplo futuro:
    <url>
      <loc>https://publientis.online/universidades/udea</loc>
      <changefreq>weekly</changefreq>
      <priority>0.8</priority>
    </url>
    <url>
      <loc>https://publientis.online/universidades/unal</loc>
      <changefreq>weekly</changefreq>
      <priority>0.8</priority>
    </url>
  -->
</urlset>
